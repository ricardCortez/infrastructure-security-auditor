# ============================================================
# Infrastructure Security Auditor – Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to source control.

# ----------------------------------------------------------
# Claude API (Anthropic)
# Required for AI-powered recommendation generation.
# Get your key at: https://console.anthropic.com/
# ----------------------------------------------------------
CLAUDE_API_KEY=sk-ant-...

# ----------------------------------------------------------
# Remote WinRM Credentials (optional – only for remote scans)
# Default: local scan (no credentials needed)
# ----------------------------------------------------------
WINRM_USERNAME=
WINRM_PASSWORD=
WINRM_PORT=5985
WINRM_TRANSPORT=ntlm

# ----------------------------------------------------------
# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=auditor.log

# ----------------------------------------------------------
# Report Output
# ----------------------------------------------------------
REPORT_OUTPUT_DIR=./reports
